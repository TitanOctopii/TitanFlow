# TitanFlow Configuration — Edge Host
# Copy to titanflow-ollie.yaml and fill in secrets, or set env vars

titanflow:
  name: "TitanFlow-Ollie"
  host: "0.0.0.0"
  port: 8800
  debug: false

  llm:
    provider: "ollama"
    base_url: "http://localhost:11434"
    default_model: "ollie-flow:latest"
    fallback_model: "qwen3:14b"
    cloud:
      provider: "anthropic"
      model: "claude-sonnet-4-5-20250929"
      api_key: "${ANTHROPIC_API_KEY}"
      escalation_threshold: 0.7

  telegram:
    bot_token: "${TELEGRAM_BOT_TOKEN_OLLIE}"
    allowed_users:
      - 8568276170  # Papa

  integrations:
    home_assistant:
      url: "http://localhost:8123"
      token: "${HASS_TOKEN}"
      enabled: false
    opnsense:
      enabled: false
    ghost:
      titanarray:
        enabled: false
      titanflow:
        enabled: false
    github:
      token: "${GITHUB_TOKEN}"
      enabled: true
    technitium:
      enabled: false
    adguard:
      enabled: false

  database:
    path: "/var/lib/titanflow/titanflow-edge.db"

  modules:
    security:
      enabled: false
    home:
      enabled: false
    automation:
      enabled: false
    webpub:
      enabled: false
    research:
      enabled: true
      fetch_interval: 7200
      max_items_per_feed: 50
      processing_batch_size: 5
    newspaper:
      enabled: false
    plugins:
      enabled: true
      dirs:
        - "~/.titanflow/plugins"
      config:
        shell-exec:
          security_mode: "allowlist"
          allowed_commands:
            - "ls"
            - "cat"
            - "head"
            - "tail"
            - "grep"
            - "find"
            - "wc"
            - "git"
            - "python3"
            - "pip"
            - "date"
            - "uptime"
            - "df"
            - "free"
            - "uname"
            - "hostname"
            - "whoami"
            - "pwd"
            - "which"
            - "echo"
            - "tree"
        file-writer:
          allowed_dirs:
            - "~/Projects"
            - "/tmp/titanflow"
        ghost-publish:
          api_url: "https://titanflow.space"
          admin_key: "${GHOST_ADMIN_KEY_FLOW}"
          default_status: "published"
          default_visibility: "public"
        ghost-autopublish:
          pipeline_logs_dir: "~/Projects/TitanPipeline/logs"
          interval_seconds: 3600
          state_file: "~/.titanflow/ghost-autopublish-state.json"
          post_tags: "titanflow,ops,automated"
          min_entries: 1

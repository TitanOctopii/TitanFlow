# TitanFlow Environment Variables
# Copy to .env and fill in real values

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token

# Ghost CMS
GHOST_ADMIN_KEY_FLOW=id:secret
GHOST_ADMIN_KEY_ARRAY=id:secret

# GitHub (for release tracking — classic PAT with public_repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Home Assistant
HASS_TOKEN=your-long-lived-access-token

# Anthropic (cloud LLM fallback)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OPNsense
OPNSENSE_KEY=your-key
OPNSENSE_SECRET=your-secret

# DNS
TECHNITIUM_TOKEN=your-api-token
ADGUARD_USER=admin
ADGUARD_PASS=your-password
